# ---- Database (Supabase Postgres + Prisma) ----
# From Supabase Connect → ORMs → Prisma (replace [YOUR-PASSWORD])
# Transaction pooler (app):
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (migrations):
DIRECT_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-1-REGION.pooler.supabase.com:5432/postgres"

# ---- Supabase Auth / client ----
NEXT_PUBLIC_SUPABASE_URL=
# New publishable key (preferred) OR classic anon JWT:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- PayHere (Phase 4) ----
NEXT_PUBLIC_PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
# sandbox | production
NEXT_PUBLIC_PAYHERE_ENV=sandbox
# Optional overrides (ngrok HTTPS for local notify_url):
# PAYHERE_NOTIFY_URL=https://xxxx.ngrok-free.dev/api/payhere/notify
# PAYHERE_CHECKOUT_BASE_URL=https://xxxx.ngrok-free.dev

# ---- App ----
# Must be HTTPS publicly reachable for PayHere notify_url (use ngrok locally).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Media (optional) ----
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
